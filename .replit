modules = ["nodejs-20", "bash"] # حذفنا موديول web لتقليل التعارض

run = "pnpm start" # هذا السطر سيقوم بتشغيل Expo مباشرة

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[nix]
packages = ["zip", "nano", "openssl"]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hilla Connect"

[[workflows.workflow]]
name = "Hilla Connect"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/hilla-connect-v2 run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"
